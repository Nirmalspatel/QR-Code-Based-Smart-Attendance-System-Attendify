###############################################################################
# Frontend environment (.env)
# CRA only exposes variables prefixed with REACT_APP_ to the browser.
# This project currently uses `proxy` in `package.json`, so env vars are optional.
###############################################################################

# Optional: change dev server port
# PORT=3000

# Optional: if you later remove `proxy`, you can use this in your axios config
# REACT_APP_API_BASE_URL=http://localhost:5051

